{
  "name": "@odience-network/paperclip-plugin-telegram-enhanced",
  "version": "0.3.1",
  "type": "module",
  "description": "Enhanced bidirectional Telegram integration for Paperclip: push notifications, bot commands, escalation, multi-agent sessions (native + ACP), media pipeline, custom workflow commands, and proactive suggestion watches. Maintained by Odience Network; enhanced fork of mvanhorn/paperclip-plugin-telegram.",
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "telegram",
    "telegram-bot",
    "bot",
    "chatbot",
    "odience-network"
  ],
  "author": "Odience Network",
  "homepage": "https://github.com/odience-network/paperclip-plugin-telegram-enhanced#readme",
  "bugs": {
    "url": "https://github.com/odience-network/paperclip-plugin-telegram-enhanced/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build-ui.mjs",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@paperclipai/shared": "*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.318.0",
    "@paperclipai/shared": "^2026.318.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odience-network/paperclip-plugin-telegram-enhanced.git"
  },
  "license": "MIT"
}
