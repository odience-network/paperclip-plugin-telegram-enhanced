{
  "name": "@odience/paperclip-plugin-telegram-enhanced",
  "version": "0.6.1",
  "description": "Enhanced Telegram plugin for Paperclip — ACP bridge, topic-to-project mapping, allowlists, and watch registry.",
  "type": "module",
  "main": "./dist/index.js",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@paperclipai/shared": "*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.318.0",
    "@paperclipai/shared": "^2026.318.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odience-network/paperclip-plugin-telegram-enhanced.git"
  },
  "homepage": "https://github.com/odience-network/paperclip-plugin-telegram-enhanced#readme",
  "bugs": {
    "url": "https://github.com/odience-network/paperclip-plugin-telegram-enhanced/issues"
  },
  "license": "MIT"
}
